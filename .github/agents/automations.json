{
  "version": 2,
  "automations": {
    "SessionStatusChange": [
      {
        "name": "CLI Validate Condition Blocked",
        "matcher": "in-progress",
        "conditions": [
          {
            "condition": "state",
            "field": "sessionStatus",
            "to": "__never-match__"
          }
        ],
        "actions": [
          {
            "type": "prompt",
            "prompt": "Reply with exactly: AUTOMATION_SHOULD_NOT_TRIGGER"
          }
        ]
      },
      {
        "name": "CLI Validate Condition Pass",
        "matcher": "in-progress",
        "conditions": [
          {
            "condition": "state",
            "field": "sessionStatus",
            "to": "in-progress"
          }
        ],
        "labels": [
          "cli-validate-label"
        ],
        "actions": [
          {
            "type": "prompt",
            "prompt": "Reply with exactly: AUTOMATION_TRIGGERED"
          },
          {
            "type": "webhook",
            "url": "http://127.0.0.1:19999/validate-webhook",
            "method": "POST",
            "bodyFormat": "json",
            "body": {
              "event": "$CRAFT_EVENT",
              "session": "$CRAFT_SESSION_ID"
            }
          }
        ]
      }
    ]
  }
}
