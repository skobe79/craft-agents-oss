{
  "name": "craft-tui-agent",
  "version": "1.0.0",
  "description": "Claude Code-like TUI agent for Craft documents",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "craft": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "link": "bun link"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "18.2.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.59",
    "@anthropic-ai/sdk": "^0.71.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@shikijs/cli": "^3.19.0",
    "chalk": "5.2.0",
    "ink": "4.1.0",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "meow": "11.0.0",
    "open": "^11.0.0",
    "react": "18.2.0",
    "shiki": "^3.19.0",
    "zod": "^3.24.1"
  }
}
