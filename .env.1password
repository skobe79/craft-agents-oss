# Development secrets via 1Password CLI
# Requires: brew install 1password-cli && op signin
#
# Usage: bun run electron:start (auto-injects secrets via op run)
# Fallback: Create .env with actual values for local override

# Google OAuth (for Gmail, Calendar, Drive connection features)
GOOGLE_OAUTH_CLIENT_ID=op://DEV_Craft_Agents/Craft Agents Gmail OAuth/client_id
GOOGLE_OAUTH_CLIENT_SECRET=op://DEV_Craft_Agents/Craft Agents Gmail OAuth/client_secret

# Slack OAuth (for Slack workspace integration)
SLACK_OAUTH_CLIENT_ID=op://DEV_Craft_Agents/Craft Agents Slack OAuth/client_id
SLACK_OAUTH_CLIENT_SECRET=op://DEV_Craft_Agents/Craft Agents Slack OAuth/client_secret

# Microsoft OAuth (for Outlook, OneDrive integration)
MICROSOFT_OAUTH_CLIENT_ID=op://DEV_Craft_Agents/Craft Agents Microsoft OAuth/client_id
MICROSOFT_OAUTH_CLIENT_SECRET=op://DEV_Craft_Agents/Craft Agents Microsoft OAuth/client_secret

# macOS Code Signing & Notarization
APPLE_SIGNING_IDENTITY="op://DEV_Craft_Agents/Craft Agents Apple Signing - Gyula Halmos/signing_identity"
APPLE_TEAM_ID=op://DEV_Craft_Agents/Craft Agents Apple Signing - Gyula Halmos/team_id
APPLE_ID=op://DEV_Craft_Agents/Craft Agents Apple Signing - Gyula Halmos/apple_id
APPLE_APP_SPECIFIC_PASSWORD=op://DEV_Craft_Agents/Craft Agents Apple Signing - Gyula Halmos/app_specific_password

# S3 Upload (for DMG distribution)
S3_VERSIONS_BUCKET_ENDPOINT=op://DEV_Craft_Agents/Craft Agents S3/endpoint
S3_VERSIONS_BUCKET_ACCESS_KEY_ID=op://DEV_Craft_Agents/Craft Agents S3/access_key_id
S3_VERSIONS_BUCKET_SECRET_ACCESS_KEY=op://DEV_Craft_Agents/Craft Agents S3/secret_access_key
