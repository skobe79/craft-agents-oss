# Development secrets via 1Password CLI
# Requires: brew install 1password-cli && op signin
#
# Usage: bun run electron:start (auto-injects secrets via op run)
# Fallback: Create .env with actual values for local override

# Gmail OAuth (for "Add Gmail" connection feature)
GMAIL_OAUTH_CLIENT_ID=op://Dev_Craft_Agents/Craft Agent Gmail OAuth/client_id
GMAIL_OAUTH_CLIENT_SECRET=op://Dev_Craft_Agents/Craft Agent Gmail OAuth/client_secret
