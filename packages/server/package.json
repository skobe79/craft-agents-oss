{
  "name": "@arch-agentz/server",
  "version": "0.10.5",
  "description": "Standalone headless Craft Agent server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "craft-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "Craft Docs Ltd.",
    "email": "support@craft.do"
  },
  "license": "Apache-2.0",
  "homepage": "https://agents.craft.do",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arch-agentz/core": "workspace:*",
    "@arch-agentz/messaging-gateway": "workspace:*",
    "@arch-agentz/server-core": "workspace:*",
    "@arch-agentz/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
